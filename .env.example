# Copia este archivo como .env y rellena tus datos.
# NUNCA subas el archivo .env real a GitHub (ya está en .gitignore).

# URL del Webhook del canal #hilos en Discord
# (Discord -> tu canal -> Editar canal -> Integraciones -> Webhooks -> Crear Webhook)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Tu nombre de usuario de Twitter/X, SIN el @
TWITTER_USER=tu_usuario

# Cuántos de tus tweets más recientes revisa el script en cada ejecución
MAX_TWEETS_TO_CHECK=50
